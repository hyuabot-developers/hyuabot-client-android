<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_quick_settings_sheet"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_sheet_grabber" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/home_quick_settings_title"
        android:textColor="@color/primary_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/presence_status_row"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_quick_settings_presence_title"
                android:textColor="@color/primary_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/shuttle_quick_settings_presence_subtitle"
                android:textColor="@color/secondary_text"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/show_presence_status_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/shuttle_quick_settings_presence_title"
            app:thumbTint="@color/shuttle_switch_thumb"
            app:trackTint="@color/shuttle_switch_track" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bus50_transfer_row"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_quick_settings_bus50_transfer_title"
                android:textColor="@color/primary_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/home_quick_settings_bus50_transfer_subtitle"
                android:textColor="@color/secondary_text"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/show_bus50_transfer_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="@color/shuttle_switch_thumb"
            app:trackTint="@color/shuttle_switch_track" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/subway_transfer_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_home_row"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_quick_settings_subway_transfer_title"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/home_quick_settings_subway_transfer_subtitle"
                    android:textColor="@color/secondary_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/show_subway_transfer_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/shuttle_switch_thumb"
                app:trackTint="@color/shuttle_switch_track" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/subway_destination_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/subway_destination_seoul"
                style="@style/Widget.App.SegmentedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:autoSizeMaxTextSize="12sp"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="@string/home_quick_settings_subway_destination_seoul"
                android:textColor="@color/home_destination_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/home_destination_button_background"
                app:strokeColor="@color/home_destination_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/subway_destination_suwon_yongin"
                style="@style/Widget.App.SegmentedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:autoSizeMaxTextSize="12sp"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="@string/home_quick_settings_subway_destination_suwon_yongin"
                android:textColor="@color/home_destination_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/home_destination_button_background"
                app:strokeColor="@color/home_destination_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/subway_destination_incheon"
                style="@style/Widget.App.SegmentedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:autoSizeMaxTextSize="12sp"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="@string/home_quick_settings_subway_destination_incheon"
                android:textColor="@color/home_destination_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/home_destination_button_background"
                app:strokeColor="@color/home_destination_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/subway_destination_oido"
                style="@style/Widget.App.SegmentedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:autoSizeMaxTextSize="12sp"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="@string/home_quick_settings_subway_destination_oido"
                android:textColor="@color/home_destination_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/home_destination_button_background"
                app:strokeColor="@color/home_destination_button_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/subway_destination_sosa"
                style="@style/Widget.App.SegmentedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:autoSizeMaxTextSize="12sp"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:maxLines="1"
                android:text="@string/home_quick_settings_subway_destination_sosa"
                android:textColor="@color/home_destination_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/home_destination_button_background"
                app:strokeColor="@color/home_destination_button_stroke" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <TextView
        android:id="@+id/legacy_shuttle_row"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_rounded_home_action"
        android:clickable="true"
        android:focusable="true"
        android:drawableStart="@drawable/ic_home_movement"
        android:drawablePadding="8dp"
        android:drawableTint="@color/hanyang_blue"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:text="@string/home_quick_settings_legacy_button"
        android:textColor="@color/hanyang_blue"
        android:textSize="17sp"
        android:textStyle="bold" />
</LinearLayout>
