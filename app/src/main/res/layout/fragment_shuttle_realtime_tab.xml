<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/bottomSheetNavHost"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <ScrollView
        android:id="@+id/shuttle_destination_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/shuttle_destination_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:paddingBottom="75dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/header_bound_for_station"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/hanyang_blue"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/shuttle_header_bound_for_station"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textFontWeight="700"
                    android:background="@color/hanyang_blue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
                <ImageButton
                    android:id="@+id/info_button_bound_for_station"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/info_button_shuttle"
                    android:src="@drawable/ic_question_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/help_bound_for_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/header_bound_for_station"
                android:visibility="gone"
                android:background="@color/hanyang_blue">
                <app.kobuggi.hyuabot.ui.shuttle.realtime.ShuttleRouteHeaderView
                    android:id="@+id/help_bound_for_station_header"
                    android:layout_width="0dp"
                    android:layout_height="25dp"
                    android:layout_marginStart="80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/help_bound_for_station_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/help_bound_for_station_header" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/realtime_view_bound_for_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/help_bound_for_station" />
            <TextView
                android:id="@+id/no_realtime_data_bound_for_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:text="@string/shuttle_no_realtime_data"
                android:textSize="18sp"
                android:textFontWeight="700"
                app:layout_constraintTop_toBottomOf="@id/realtime_view_bound_for_station" />
            <Button
                android:id="@+id/entire_timetable_bound_for_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/no_realtime_data_bound_for_station" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/header_bound_for_dormitory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_bound_for_station"
                android:background="@color/hanyang_blue">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/shuttle_header_bound_for_dormitory"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textFontWeight="700"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
                <ImageButton
                    android:id="@+id/info_button_bound_for_dormitory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/info_button_shuttle"
                    android:src="@drawable/ic_question_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/help_bound_for_dormitory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/header_bound_for_dormitory"
                android:visibility="gone"
                android:background="@color/hanyang_blue">
                <app.kobuggi.hyuabot.ui.shuttle.realtime.ShuttleRouteHeaderView
                    android:id="@+id/help_bound_for_dormitory_header"
                    android:layout_width="0dp"
                    android:layout_height="25dp"
                    android:layout_marginStart="80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/help_bound_for_dormitory_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/help_bound_for_dormitory_header" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/realtime_view_bound_for_dormitory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/help_bound_for_dormitory" />
            <TextView
                android:id="@+id/no_realtime_data_bound_for_dormitory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:text="@string/shuttle_no_realtime_data"
                android:textSize="18sp"
                android:textFontWeight="700"
                app:layout_constraintTop_toBottomOf="@id/realtime_view_bound_for_dormitory" />
            <Button
                android:id="@+id/entire_timetable_bound_for_dormitory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/no_realtime_data_bound_for_dormitory" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/header_bound_for_terminal"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_bound_for_dormitory"
                android:background="@color/hanyang_blue">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/shuttle_header_bound_for_terminal"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textFontWeight="700"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
                <ImageButton
                    android:id="@+id/info_button_bound_for_terminal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/info_button_shuttle"
                    android:src="@drawable/ic_question_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/help_bound_for_terminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/header_bound_for_terminal"
                android:visibility="gone"
                android:background="@color/hanyang_blue">
                <app.kobuggi.hyuabot.ui.shuttle.realtime.ShuttleRouteHeaderView
                    android:id="@+id/help_bound_for_terminal_header"
                    android:layout_width="0dp"
                    android:layout_height="25dp"
                    android:layout_marginStart="80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/help_bound_for_terminal_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/help_bound_for_terminal_header" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/realtime_view_bound_for_terminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/help_bound_for_terminal" />
            <TextView
                android:id="@+id/no_realtime_data_bound_for_terminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:text="@string/shuttle_no_realtime_data"
                android:textSize="18sp"
                android:textFontWeight="700"
                app:layout_constraintTop_toBottomOf="@id/realtime_view_bound_for_terminal" />
            <Button
                android:id="@+id/entire_timetable_bound_for_terminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/no_realtime_data_bound_for_terminal" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/header_bound_for_jungang_station"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_bound_for_terminal"
                android:background="@color/hanyang_blue">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/shuttle_header_bound_for_jungang_station"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textFontWeight="700"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
                <ImageButton
                    android:id="@+id/info_button_bound_for_jungang_station"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/info_button_shuttle"
                    android:src="@drawable/ic_question_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/help_bound_for_jungang_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/header_bound_for_jungang_station"
                android:visibility="gone"
                android:background="@color/hanyang_blue">
                <app.kobuggi.hyuabot.ui.shuttle.realtime.ShuttleRouteHeaderView
                    android:id="@+id/help_bound_for_jungang_station_header"
                    android:layout_width="0dp"
                    android:layout_height="25dp"
                    android:layout_marginStart="80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/help_bound_for_jungang_station_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/help_bound_for_jungang_station_header" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/realtime_view_bound_for_jungang_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/help_bound_for_jungang_station" />
            <TextView
                android:id="@+id/no_realtime_data_bound_for_jungang_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:text="@string/shuttle_no_realtime_data"
                android:textSize="18sp"
                android:textFontWeight="700"
                app:layout_constraintTop_toBottomOf="@id/realtime_view_bound_for_jungang_station" />
            <Button
                android:id="@+id/entire_timetable_bound_for_jungang_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/no_realtime_data_bound_for_jungang_station" />
            <Button
                android:id="@+id/stop_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_stop_info"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_bound_for_jungang_station" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <ScrollView
        android:id="@+id/shuttle_time_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/shuttle_time_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:paddingBottom="75dp">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/realtime_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:id="@+id/no_realtime_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center"
                android:text="@string/shuttle_no_realtime_data"
                android:textSize="18sp"
                android:textFontWeight="700"
                app:layout_constraintTop_toBottomOf="@id/realtime_view" />
            <Button
                android:id="@+id/entire_timetable_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable_station"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/no_realtime_data" />
            <Button
                android:id="@+id/entire_timetable_dormitory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable_dormitory"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_station" />
            <Button
                android:id="@+id/entire_timetable_terminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable_terminal"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_dormitory" />
            <Button
                android:id="@+id/entire_timetable_jungang_station"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_entire_timetable_jungang_station"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_terminal" />
            <Button
                android:id="@+id/stop_info_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shuttle_footer_stop_info"
                android:textSize="18sp"
                android:textFontWeight="700"
                style="@style/Widget.Material3.Button.TextButton"
                app:layout_constraintTop_toBottomOf="@id/entire_timetable_jungang_station" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</FrameLayout>
