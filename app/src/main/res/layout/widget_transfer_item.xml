<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="3dp"
    android:background="@drawable/bg_widget_surface"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="9dp"
    android:paddingVertical="7dp">

    <TextView
        android:id="@+id/widget_transfer_name"
        android:fontFamily="@font/godo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:maxWidth="116dp"
        android:minWidth="76dp"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_transfer_detail"
        android:fontFamily="@font/godo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFeatureSettings="tnum"
        android:textColor="@color/widget_primary_text"
        android:textSize="13sp" />
</LinearLayout>
