<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_transfer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_shuttle"
            android:tint="@color/widget_accent"
            android:contentDescription="@string/shuttle_bus" />

        <TextView
            android:id="@+id/widget_transfer_title"
            android:fontFamily="@font/godo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/widget_accent"
            android:text="@string/widget_shuttle_transfer_name" />

        <TextView
            android:id="@+id/widget_transfer_stop"
            android:fontFamily="@font/godo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/widget_secondary_text" />

        <ImageView
            android:id="@+id/widget_transfer_refresh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="-8dp"
            android:padding="8dp"
            android:src="@drawable/ic_widget_refresh"
            android:tint="@color/widget_accent"
            android:contentDescription="@string/widget_cafeteria_refresh" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:importantForAccessibility="no"
        android:background="@color/widget_divider" />

    <TextView
        android:id="@+id/widget_transfer_empty"
        android:fontFamily="@font/godo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/widget_secondary_text"
        android:visibility="gone"
        android:text="@string/widget_shuttle_no_data" />

    <LinearLayout
        android:id="@+id/widget_transfer_shuttle_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <ImageView
        android:id="@+id/widget_transfer_section_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="6dp"
        android:importantForAccessibility="no"
        android:background="@color/widget_divider" />

    <TextView
        android:id="@+id/widget_transfer_section_title"
        android:fontFamily="@font/godo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/widget_accent"
        android:text="@string/shuttle_transfer_section_title" />

    <LinearLayout
        android:id="@+id/widget_transfer_transit_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />
</LinearLayout>
