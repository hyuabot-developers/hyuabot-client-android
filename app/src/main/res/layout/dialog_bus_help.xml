<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/hanyang_blue"
            app:menu="@menu/full_screen_menu"
            app:title="@string/bus_help_title"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/help_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/realtime_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="@string/bus_help_realtime_title"
                android:textColor="@color/primary_text"
                android:textFontWeight="600"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/realtime_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/bus_help_realtime_content"
                android:textColor="@color/secondary_text"
                android:textSize="17sp" />

            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/calendar_grid_line" />

            <TextView
                android:id="@+id/stop_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="@string/bus_help_stop_title"
                android:textColor="@color/primary_text"
                android:textFontWeight="600"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/stop_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/bus_help_stop_content"
                android:textColor="@color/secondary_text"
                android:textSize="17sp" />

            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/calendar_grid_line" />

            <TextView
                android:id="@+id/timetable_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="@string/bus_help_timetable_title"
                android:textColor="@color/primary_text"
                android:textFontWeight="600"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/timetable_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/bus_help_timetable_content"
                android:textColor="@color/secondary_text"
                android:textSize="17sp" />

            <View
                android:id="@+id/divider3"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/calendar_grid_line" />

            <TextView
                android:id="@+id/departure_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="@string/bus_help_departure_title"
                android:textColor="@color/primary_text"
                android:textFontWeight="600"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/departure_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/bus_help_departure_content"
                android:textColor="@color/secondary_text"
                android:textSize="17sp" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
