<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_meal_lunch"
            android:contentDescription="@string/widget_cafeteria_name" />

        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/hanyang_blue"
            android:text="@string/cafeteria_tab_lunch" />

        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="11sp"
            android:textColor="@color/secondary_text"
            android:text="12:30" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_refresh"
            android:contentDescription="@string/widget_cafeteria_refresh" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:importantForAccessibility="no"
        android:background="@color/hanyang_blue_variant" />

    <TextView
        android:fontFamily="@font/godo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/primary_text"
        android:text="@string/widget_preview_cafeteria_student" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="1dp"
        android:layout_marginTop="2dp">
        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="@color/secondary_text"
            android:text="@string/widget_preview_menu_spicy_pork" />
        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="@color/hanyang_blue"
            android:text="5,000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="1dp">
        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="@color/secondary_text"
            android:text="@string/widget_preview_menu_kimchi_stew" />
        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="@color/hanyang_blue"
            android:text="4,500" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="6dp"
        android:importantForAccessibility="no"
        android:background="@color/hanyang_blue_variant" />

    <TextView
        android:fontFamily="@font/godo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/primary_text"
        android:text="@string/widget_preview_cafeteria_staff" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="1dp"
        android:layout_marginTop="2dp">
        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="@color/secondary_text"
            android:text="@string/widget_preview_menu_pork_cutlet" />
        <TextView
            android:fontFamily="@font/godo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="@color/hanyang_blue"
            android:text="6,000" />
    </LinearLayout>
</LinearLayout>
