<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/menu_item_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp" >
    <TextView
        android:id="@+id/menu_section_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:textColor="@color/secondary_text"
        android:textFontWeight="700"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="학교생활" />
    <ImageView
        android:id="@+id/menu_icon_view"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="menu icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/menu_section_text_view"
        app:layout_constraintBottom_toBottomOf="parent"
        app:tint="@color/primary_text"
        tools:ignore="HardcodedText" />
    <TextView
        android:id="@+id/menu_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/primary_text"
        android:textFontWeight="700"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/menu_icon_view"
        app:layout_constraintEnd_toStartOf="@id/menu_arrow_view"
        app:layout_constraintTop_toTopOf="@id/menu_icon_view"
        app:layout_constraintBottom_toBottomOf="@id/menu_icon_view"
    />
    <ImageView
        android:id="@+id/menu_arrow_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="menu arrow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/menu_icon_view"
        app:layout_constraintBottom_toBottomOf="parent"
        android:src="@drawable/ic_arrow_right"
        app:tint="@color/secondary_text"
        tools:ignore="HardcodedText" />
</androidx.constraintlayout.widget.ConstraintLayout>
