<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/menu_row_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:minHeight="58dp"
    android:paddingVertical="10dp">

    <ImageView
        android:id="@+id/menu_icon_view"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="menu icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:tint="@color/primary_text"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/menu_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/primary_text"
        android:textFontWeight="700"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/menu_icon_view"
        app:layout_constraintEnd_toStartOf="@id/menu_arrow_view"
        app:layout_constraintTop_toTopOf="@id/menu_icon_view"
        app:layout_constraintBottom_toBottomOf="@id/menu_icon_view"
        tools:text="열람실 좌석 조회" />

    <ImageView
        android:id="@+id/menu_arrow_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="menu arrow"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/menu_icon_view"
        app:layout_constraintBottom_toBottomOf="@id/menu_icon_view"
        app:tint="@color/secondary_text"
        tools:ignore="HardcodedText" />
</androidx.constraintlayout.widget.ConstraintLayout>
