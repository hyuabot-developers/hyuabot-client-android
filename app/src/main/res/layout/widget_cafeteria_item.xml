<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_widget_surface"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_item_name"
            android:fontFamily="@font/godo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/widget_primary_text" />

        <TextView
            android:id="@+id/widget_item_running_time"
            android:fontFamily="@font/godo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_badge"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="7dp"
            android:paddingVertical="2dp"
            android:textSize="11sp"
            android:textColor="@color/widget_secondary_text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_menu_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="2dp" />
</LinearLayout>
