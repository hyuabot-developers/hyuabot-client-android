<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.HYUabot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@android:color/background_light</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@mipmap/ic_launcher</item>
        <item name="colorPrimary">@color/hanyang_blue</item>
        <item name="colorPrimaryVariant">@color/hanyang_blue</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/hanyang_green</item>
        <item name="colorSecondaryVariant">@color/hanyang_green</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:colorBackground">@android:color/background_light</item>
        <item name="android:colorError">@color/hanyang_orange</item>
        <item name="colorOnError">@color/hanyang_orange</item>
        <item name="colorOnBackground">@color/hanyang_silver</item>
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
        <!-- Prevent Material3 bottom sheet dialogs from calling deprecated
             Window.setStatusBarColor / setNavigationBarColor on API 35+.
             Edge-to-edge for these dialogs is already handled by the Activity's enableEdgeToEdge(). -->
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>
        <!-- Text Appearances -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.App.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.App.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.App.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.App.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.App.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.App.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.App.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.App.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.App.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.App.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.App.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.App.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.App.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.App.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.App.LabelSmall</item>
        <!-- Popup Menu -->
        <item name="popupMenuBackground">@drawable/custom_popup_background</item>
        <!-- Status Bar: icon color for pre-API-35 devices (API 35+ handled by enableEdgeToEdge) -->
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.BottomNavigationView</item>
    </style>
    <style name="ThemeOverlay.App.BottomNavigationView" parent="">
        <item name="colorSurfaceContainer">@color/background</item>
        <item name="colorOnSurfaceVariant">@color/bottom_navigation_unselected</item>
        <item name="colorOnSecondaryContainer">@color/hanyang_blue</item>
        <item name="colorOnSurface">@color/hanyang_blue</item>
        <item name="colorSecondaryContainer">@color/bottom_navigation_indicator</item>
    </style>
    <style name="TextAppearance.App.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/godo</item>
        <item name="android:fontFamily">@font/godo</item>
    </style>
    <style name="TextAppearance.App.Tab" parent="TextAppearance.App.TitleSmall">
        <item name="android:textSize">18sp</item>
    </style>
    <style name="Widget.App.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="colorOnSurfaceVariant">@android:color/white</item>
    </style>
    <style name="StatusBarStyle" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="backgroundColor">@color/hanyang_blue</item>
    </style>
    <style name="Widget.App.Switch.Shuttle" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Switch</item>
    </style>

    <style name="Widget.App.SegmentedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/godo</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/home_destination_button_text</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">@color/home_destination_button_background</item>
        <item name="cornerRadius">22dp</item>
        <item name="strokeColor">@color/home_destination_button_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.App.HomeSegmentButton" parent="Widget.App.SegmentedButton">
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.App.HomeHeaderButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/godo</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/home_detail_button_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="Widget.App.HomeSelectorButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/godo</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="iconPadding">5dp</item>
        <item name="iconTint">@color/primary_text</item>
    </style>

    <style name="Widget.App.FilledActionButton" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/godo</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/hanyang_blue</item>
    </style>

    <style name="Widget.App.PlainFooterButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/godo</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/plain_button_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="iconTint">@color/plain_button_text</item>
    </style>

    <style name="ThemeOverlay.App.Switch" parent="">
        <item name="colorPrimary">@android:color/white</item>
        <item name="colorOnPrimary">@color/hanyang_blue</item>
    </style>
    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <!-- Disable Material3's internal edge-to-edge setup for bottom sheet dialogs.
             The Activity already calls enableEdgeToEdge(); letting the library also call
             Window.setStatusBarColor / setNavigationBarColor triggers deprecated-API warnings
             on Android 15 (API 35+). With this flag off, SheetDialog.onCreate skips
             EdgeToEdgeUtils.applyEdgeToEdge() entirely. -->
        <item name="enableEdgeToEdge">false</item>
    </style>
</resources>
