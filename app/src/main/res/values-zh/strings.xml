    <string name="coachmark_shuttle_nav_title">一目了然的校园信息</string>
    <string name="coachmark_shuttle_nav_desc">通过标签切换校车、公交、地铁、食堂信息。菜单标签中还有更多功能。</string>
    <string name="coachmark_shuttle_tab_title">选择站点</string>
    <string name="coachmark_shuttle_tab_desc">滑动或点击标签，查看各站点的实时到达信息。</string>
    <string name="coachmark_shuttle_destination_title">按目的地查看</string>
    <string name="coachmark_shuttle_destination_desc">打开此开关，即可按目的地分组查看。现在打开。</string>
    <string name="coachmark_shuttle_departure_title">显示出发时间</string>
    <string name="coachmark_shuttle_departure_desc">打开此开关，即可查看各班车的出发时间。</string>
    <string name="coachmark_shuttle_route_title">各路线途经站点</string>
    <string name="coachmark_shuttle_route_desc">点击目的地标题旁的按钮，可展开查看各路线途经的站点。</string>
    <string name="coachmark_shuttle_via_title">途经站点与所需时间</string>
    <string name="coachmark_shuttle_via_desc">点击到达条目，可查看该班车在各站点的出发时间。</string>
    <string name="coachmark_shuttle_transfer_title">换乘信息</string>
    <string name="coachmark_shuttle_transfer_desc">在宿舍、羽毛球场站，可在到达信息下方查看换乘路线。</string>
    <string name="coachmark_shuttle_stop_title">站点信息</string>
    <string name="coachmark_shuttle_stop_desc">结合地图查看站点位置及首末班时间。</string>
    <string name="coachmark_shuttle_help_title">校车帮助</string>
    <string name="coachmark_shuttle_help_desc">可查看失物认领、时刻表未执行投诉等附加说明。</string>
    <string name="coachmark_shuttle_timetable_tab_title">工作日·周末时刻表</string>
    <string name="coachmark_shuttle_timetable_tab_desc">点击标签切换工作日和周末的运行时刻表。</string>
    <string name="coachmark_shuttle_timetable_filter_title">选择运行期间</string>
    <string name="coachmark_shuttle_timetable_filter_desc">点击此按钮可选择学期、假期等运行期间来切换时刻表。</string>
    <string name="coachmark_bus_tab_title">选择公交类型</string>
    <string name="coachmark_bus_tab_desc">通过标签切换市内公交、江南站方向、水原站方向等，查看实时到达信息。</string>
    <string name="coachmark_bus_stop_title">选择站点</string>
    <string name="coachmark_bus_stop_desc">点击此按钮可选择您想查看的站点。</string>
    <string name="coachmark_subway_tab_title">切换路线·换乘</string>
    <string name="coachmark_subway_tab_desc">点击标签查看4号线、水仁盆唐线的实时到达及换乘信息。</string>
    <string name="coachmark_cafeteria_tab_title">早餐·午餐·晚餐</string>
    <string name="coachmark_cafeteria_tab_desc">点击标签查看各餐次的学食菜单。</string>
    <string name="coachmark_cafeteria_date_title">选择日期</string>
    <string name="coachmark_cafeteria_date_desc">可直接选择日期，或使用左右按钮查看其他日期的菜单。</string>
    <string name="coachmark_menu_title">更多功能</string>
    <string name="coachmark_menu_desc">可从这里进入阅览室、校园地图、联系方式、学事历和设置。</string>
    <string name="coachmark_reading_room_seats_title">实时座位状况</string>
    <string name="coachmark_reading_room_seats_desc">实时查看各阅览室剩余座位，向下拉动可刷新。</string>
    <string name="coachmark_reading_room_alarm_title">座位提醒</string>
    <string name="coachmark_reading_room_alarm_desc">设置3小时、4小时后的座位延长提醒，以免忘记。</string>
    <string name="coachmark_map_search_title">搜索建筑·教室</string>
    <string name="coachmark_map_search_desc">搜索建筑或教室名称，在校园地图中查看位置。</string>
    <string name="coachmark_setting_campus_title">选择校区</string>
    <string name="coachmark_setting_campus_desc">先设置校区，校车、食堂、阅览室信息将正确显示。</string>
    <string name="coachmark_setting_theme_title">语言·主题</string>
    <string name="coachmark_setting_theme_desc">可随意更改语言和界面主题（浅色·深色）。</string>
    <string name="coachmark_bus_log_title">查看出发记录</string>
    <string name="coachmark_bus_log_desc">点击各公交的「出发记录」按钮，可查看该站点昨天、前天、1周前的出发记录。</string>
    <string name="coachmark_subway_transfer_tip_title">换乘可能更快</string>
    <string name="coachmark_subway_transfer_tip_desc">汉大前至仁川的直通列车约30分钟一班。汉大前至五耳岛、五耳岛至仁川的列车每7至15分钟一班，在五耳岛换乘可能更快。</string>
    <string name="coachmark_shuttle_widget_title">校车小组件</string>
    <string name="coachmark_shuttle_widget_desc">在主屏幕添加「校车」小组件和「校车+换乘」小组件，无需打开应用即可直接查看最近站点的到达及换乘信息。</string>
    <string name="coachmark_cafeteria_widget_title">学食小组件</string>
    <string name="coachmark_cafeteria_widget_desc">在主屏幕添加「学食」小组件，可随时查看今日菜单。</string>
